{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://localhost:3000/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "https://api.staging.travelplanner.app/api"
      }
    },
    "production": {
      "env": {
        "API_URL": "https://api.travelplanner.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
