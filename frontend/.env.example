# API Configuration
# Development: http://localhost:3000/api
# Production: /api (nginx proxies to backend)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# OAuth Configuration (for web preview)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
KAKAO_CLIENT_ID=

# Google Maps (for map view)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Google AdSense (Web only)
# Get from: https://www.google.com/adsense → Sites → Ad units
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_DEFAULT_SLOT=

# Google AdMob (Native iOS/Android only)
# Get from: https://apps.admob.com → Apps → Ad units
ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
ADMOB_ANDROID_BANNER_ID=
ADMOB_IOS_BANNER_ID=
ADMOB_ANDROID_INTERSTITIAL_ID=
ADMOB_IOS_INTERSTITIAL_ID=
# App Open Ads — shown on foreground return
# Get from: https://apps.admob.com → Apps → Ad units → App Open
ADMOB_ANDROID_APP_OPEN_ID=
ADMOB_IOS_APP_OPEN_ID=
# Rewarded Ads — user watches video for bonus insights
# Get from: https://apps.admob.com → Apps → Ad units → Rewarded
ADMOB_ANDROID_REWARDED_ID=
ADMOB_IOS_REWARDED_ID=

# Affiliate IDs
# Booking.com: https://www.booking.com/affiliate-program
# Expedia: https://www.expediagroup.com/affiliates
# Klook: https://affiliate.klook.com
AFFILIATE_BOOKING_ID=
AFFILIATE_EXPEDIA_ID=
AFFILIATE_HOTELS_ID=
AFFILIATE_AIRBNB_ID=
AFFILIATE_VIATOR_ID=
AFFILIATE_KLOOK_ID=

# Sentry (Error Monitoring)
SENTRY_DSN=

# EAS Build
EAS_PROJECT_ID=

# Environment
NODE_ENV=development
