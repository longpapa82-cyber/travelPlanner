# ==========================================
# TravelPlanner Frontend — Production Config
# ==========================================
# Used during Docker build for web production

# API Configuration (nginx proxies to backend)
EXPO_PUBLIC_API_URL=https://api.travelplanner.app/api

# OAuth (for web)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=your-apple-client-id
KAKAO_CLIENT_ID=your-kakao-rest-api-key

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Google AdSense (Web only)
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_DEFAULT_SLOT=

# Google AdMob (Native only)
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=
ADMOB_ANDROID_BANNER_ID=
ADMOB_IOS_BANNER_ID=
ADMOB_ANDROID_INTERSTITIAL_ID=
ADMOB_IOS_INTERSTITIAL_ID=

# Affiliate IDs
AFFILIATE_BOOKING_ID=
AFFILIATE_EXPEDIA_ID=
AFFILIATE_HOTELS_ID=
AFFILIATE_AIRBNB_ID=
AFFILIATE_VIATOR_ID=
AFFILIATE_KLOOK_ID=

# Sentry
SENTRY_DSN=

# EAS Build
EAS_PROJECT_ID=6834aeb3-58dd-4d9d-a3a3-19824beb9e62

# Environment
NODE_ENV=production
