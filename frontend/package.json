{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "expo lint"
  },
  "overrides": {
    "minimatch": ">=9.0.5",
    "glob": ">=10.4.0",
    "tar": ">=7.5.8"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|react-native-reanimated|react-native-gesture-handler|react-native-screens|react-native-safe-area-context|@react-native-async-storage/async-storage|react-native-paper|react-native-vector-icons|react-native-keychain|react-native-google-mobile-ads|expo-tracking-transparency|expo-web-browser|expo-linking|expo-crypto|expo-localization|i18next|react-i18next|@tanstack/react-query)"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.{ts,tsx}",
      "src/hooks/**/*.{ts,tsx}",
      "src/utils/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.11.0",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.5",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-crypto": "~15.0.8",
    "expo-device": "^8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "^17.0.8",
    "expo-notifications": "^0.32.16",
    "expo-sharing": "^14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-keychain": "^10.0.0",
    "react-native-paper": "^5.14.5",
    "react-native-purchases": "^9.10.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "react-native-worklets": "^0.7.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
