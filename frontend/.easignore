# .easignore - Optimize EAS Build Upload Size
# Current: 405 MB → Target: 100-150 MB
# Exclude files/folders not needed for remote build

# ============================================
# Development Tools & Build Artifacts
# ============================================
build-tools/
platforms/
platform-tools/
dist/
build/
.expo/
.expo-shared/

# ============================================
# Testing & Coverage
# ============================================
coverage/
test-results/
__tests__/
*.test.ts
*.test.tsx
*.test.js
*.spec.ts
*.spec.tsx
*.spec.js

# ============================================
# Documentation
# ============================================
docs/
*.md
!README.md
store-metadata/
licenses/

# ============================================
# Git & Version Control
# ============================================
.git/
.github/
.gitignore
.gitattributes

# ============================================
# IDE & Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Logs & Temporary Files
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
tmp/
temp/

# ============================================
# CI/CD (not needed for EAS build)
# ============================================
.circleci/
.travis.yml
.gitlab-ci.yml
azure-pipelines.yml

# ============================================
# Scripts (dev-only)
# ============================================
scripts/
*.sh

# ============================================
# Large Assets (if not used in app)
# ============================================
# Uncomment if you have large unused assets
# assets/large-videos/
# assets/raw/
# assets/unused/

# ============================================
# Environment Files (use EAS Secrets instead)
# ============================================
.env.local
.env.development
.env.test
.env*.local

# ============================================
# Package Manager
# ============================================
# node_modules is already excluded by EAS by default
.yarn/
.pnp.*
yarn.lock
package-lock.json

# ============================================
# Web-specific (for mobile-only builds)
# ============================================
web/
public/favicon.ico
public/manifest.json
public/robots.txt

# ============================================
# Plugins (if using custom dev plugins)
# ============================================
# plugins/
