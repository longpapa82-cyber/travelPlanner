# ========================================
# OAuth 설정 템플릿
# ========================================
# 이 파일을 참고하여 .env 파일에 실제 값을 입력하세요.
# 각 Provider의 등록 방법은 /claudedocs/oauth-client-registration-guide.md 참조

# ========================================
# Google OAuth 2.0
# ========================================
# 등록: https://console.cloud.google.com/
# 1. 프로젝트 생성
# 2. OAuth 동의 화면 구성
# 3. OAuth 클라이언트 ID 만들기 (웹 애플리케이션)
# 4. 승인된 리디렉션 URI 추가

GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ========================================
# Apple Sign-In
# ========================================
# 등록: https://developer.apple.com/
# 주의: Apple Developer Program 계정 필요 ($99/year)
# 1. Services ID 생성
# 2. Sign In with Apple 구성
# 3. Key 생성 및 .p8 파일 다운로드
# 4. Team ID 확인

APPLE_CLIENT_ID=com.yourcompany.travelplanner.signin
APPLE_TEAM_ID=ABC123XYZ
APPLE_KEY_ID=DEF456UVW
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey_DEF456UVW.p8
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback

# ========================================
# Kakao OAuth 2.0
# ========================================
# 등록: https://developers.kakao.com/
# 1. 애플리케이션 추가
# 2. 플랫폼 설정 (Web)
# 3. 카카오 로그인 활성화
# 4. Redirect URI 등록
# 5. 동의 항목 설정

KAKAO_CLIENT_ID=your-rest-api-key
KAKAO_CLIENT_SECRET=your-client-secret
KAKAO_CALLBACK_URL=http://localhost:3000/api/auth/kakao/callback

# ========================================
# Frontend Deep Link
# ========================================
# 개발: Expo Dev Server URL
# 프로덕션: 앱 scheme (app.json에서 설정)

FRONTEND_URL=exp://localhost:8081

# ========================================
# 프로덕션 설정 예시 (배포 시)
# ========================================

# GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback
# APPLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/apple/callback
# KAKAO_CALLBACK_URL=https://api.yourdomain.com/api/auth/kakao/callback
# FRONTEND_URL=travelplanner://
