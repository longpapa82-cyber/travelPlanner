# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=travelplanner
# DB_SSL=true              # Enable SSL for managed DB (RDS, Cloud SQL)
# DB_SSL_REJECT_UNAUTHORIZED=true  # Verify server certificate (default: true)
# DB_SSL_CA=/path/to/ca.pem       # CA certificate for managed DB

# JWT (REQUIRED in production — server won't start without these)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=30d

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OAuth - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./secrets/apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback

# OAuth - Kakao
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_CALLBACK_URL=http://localhost:3000/api/auth/kakao/callback

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=your-openai-org-id

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_me

# Sentry (Error Monitoring)
SENTRY_DSN=

# CORS
CORS_ORIGIN=http://localhost:19006,http://localhost:19000,exp://localhost:8081

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# OpenWeather API
OPENWEATHER_API_KEY=your-openweather-api-key

# Template Cache
TEMPLATE_AUTO_SEED=false

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@travelplanner.com

# Frontend URL (for OAuth callback redirect & email links)
FRONTEND_URL=http://localhost:8081

# RevenueCat (Subscription)
REVENUECAT_WEBHOOK_SECRET=
AI_TRIPS_FREE_LIMIT=3
