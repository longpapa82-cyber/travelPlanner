# ==========================================
# TravelPlanner Backend — Production Config
# ==========================================
# Copy this to .env on production server

# Application
NODE_ENV=production
PORT=3000
API_PREFIX=api

# Database (Docker internal network)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=travelplanner
DB_PASSWORD=CHANGE_ME_strong_random_password_32chars
DB_DATABASE=travelplanner

# JWT (MUST change in production — use: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=CHANGE_ME_use_openssl_rand_base64_64
JWT_REFRESH_EXPIRATION=30d

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.travelplanner.app/api/auth/google/callback

# OAuth - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./secrets/apple-private-key.p8
APPLE_CALLBACK_URL=https://api.travelplanner.app/api/auth/apple/callback

# OAuth - Kakao
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_CALLBACK_URL=https://api.travelplanner.app/api/auth/kakao/callback

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Redis (Docker internal network)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_random_password_32chars

# Sentry (Error Monitoring)
SENTRY_DSN=https://your-sentry-dsn

# CORS (production frontend domain)
CORS_ORIGIN=https://travelplanner.app,https://www.travelplanner.app

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# OpenWeather API
OPENWEATHER_API_KEY=your-openweather-api-key

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@travelplanner.app
FRONTEND_URL=https://travelplanner.app

# Paddle (Web Payments)
PADDLE_API_KEY=pdl_live_your-paddle-api-key
PADDLE_WEBHOOK_SECRET=pdl_ntfset_your-webhook-secret
PADDLE_PRICE_MONTHLY=pri_monthly_price_id
PADDLE_PRICE_YEARLY=pri_yearly_price_id

# Geocoding (LocationIQ)
LOCATIONIQ_API_KEY=your-locationiq-api-key
