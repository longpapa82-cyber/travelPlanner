<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Your Email - MyTravel</title>
</head>
<body style="margin: 0; padding: 0; background-color: #F3F4F6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; -webkit-font-smoothing: antialiased;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #F3F4F6; padding: 40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%; background-color: #FFFFFF; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);">
          <!-- Header -->
          <tr>
            <td align="center" style="background: linear-gradient(135deg, #3B82F6, #2563EB); padding: 32px 24px;">
              <div style="font-size: 36px; margin-bottom: 8px;">✉️</div>
              <h1 style="margin: 0; color: #FFFFFF; font-size: 22px; font-weight: 700; letter-spacing: -0.02em;">MyTravel</h1>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding: 40px 32px 24px;">
              <h2 style="margin: 0 0 16px; color: #111827; font-size: 20px; font-weight: 700; text-align: center;">Verify Your Email</h2>
              <p style="margin: 0 0 32px; color: #4B5563; font-size: 15px; line-height: 1.6; text-align: center;">
                Hello {{name}}, please click the button below to verify your email.
              </p>
              <!-- CTA Button -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding-bottom: 24px;">
                    <a href="{{verificationUrl}}" target="_blank" style="display: inline-block; background: linear-gradient(135deg, #3B82F6, #2563EB); color: #FFFFFF; text-decoration: none; font-size: 15px; font-weight: 600; padding: 14px 32px; border-radius: 8px; letter-spacing: 0.02em;">Verify Email</a>
                  </td>
                </tr>
              </table>
              <!-- Fallback Link -->
              <p style="margin: 0 0 8px; color: #6B7280; font-size: 13px; text-align: center;">
                If the button doesn't work, copy the link below:
              </p>
              <p style="margin: 0 0 32px; color: #3B82F6; font-size: 13px; text-align: center; word-break: break-all;">
                {{verificationUrl}}
              </p>
              <!-- Expiry Warning -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="background-color: #FEF3C7; border-radius: 8px; padding: 14px 20px;">
                    <p style="margin: 0; color: #92400E; font-size: 13px; text-align: center; line-height: 1.5;">
                      ⏳ This link expires in 24 hours.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Security Note -->
          <tr>
            <td style="padding: 0 32px 24px;">
              <p style="margin: 0; color: #9CA3AF; font-size: 12px; text-align: center; line-height: 1.5;">
                If you did not request this, please ignore this email.
              </p>
            </td>
          </tr>
          <!-- Divider -->
          <tr>
            <td style="padding: 0 32px;">
              <div style="border-top: 1px solid #E5E7EB;"></div>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding: 24px 32px;">
              <p style="margin: 0; color: #9CA3AF; font-size: 12px; text-align: center; line-height: 1.5;">
                &copy; 2025 MyTravel. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
